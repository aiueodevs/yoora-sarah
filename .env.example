# Root local environment
# Copy to: .env at the repository root.
# This is the main local development env used by the api service and shared tooling.

# --- Core backend / shared local URLs ---
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
API_PORT=8000
YOORA_INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
YOORA_STOREFRONT_API_BASE_URL=http://127.0.0.1:8000/api/v1
YOORA_INTERNAL_API_SHARED_SECRET=replace-with-internal-api-shared-secret

# --- Portal auth / internal app ---
YOORA_PORTAL_AUTH_SECRET=replace-with-32-plus-char-secret
YOORA_PORTAL_BOOTSTRAP_PASSWORD=replace-with-temporary-internal-password
ALLOW_INSECURE_AUTH=false

# --- Supabase ---
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_[PROJECT-PUBLISHABLE-KEY]
SUPABASE_SECRET_KEY=sb_secret_[PROJECT-SECRET-KEY]
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_[PROJECT-PUBLISHABLE-KEY]

# --- Optional local AI / app integrations ---
REDIS_URL=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
YOORA_STYLIST_IMAGE_ANALYSIS_GEMINI_API_KEY=
YOORA_STYLIST_IMAGE_ANALYSIS_GEMINI_MODEL=gemini-2.5-flash
YOORA_STYLIST_PRODUCT_TO_MODEL_PROVIDER=mock
YOORA_STYLIST_PRODUCT_TO_MODEL_GEMINI_MODEL=gemini-2.5-flash-image
YOORA_STYLIST_PRODUCT_TO_MODEL_OPENAI_MODEL=gpt-image-1
YOORA_STYLIST_PRODUCT_TO_MODEL_OPENAI_SIZE=1024x1536
YOORA_STYLIST_PRODUCT_TO_MODEL_OPENAI_QUALITY=medium
YOORA_STYLIST_PRODUCT_TO_MODEL_OPENAI_INPUT_FIDELITY=high
REPLICATE_API_TOKEN=
YOORA_STYLIST_PRODUCT_TO_MODEL_REPLICATE_OWNER=
YOORA_STYLIST_PRODUCT_TO_MODEL_REPLICATE_DEPLOYMENT=
YOORA_STYLIST_PRODUCT_TO_MODEL_REPLICATE_INPUT_TEMPLATE={"product_image":"{{product_image}}","prompt":"{{prompt}}","model_direction":"{{model_direction}}","background":"{{background}}"}

# --- Optional object storage ---
OBJECT_STORAGE_BUCKET=yoora-sarah
OBJECT_STORAGE_ENDPOINT=https://[CLOUDFLARE-ACCOUNT-ID].r2.cloudflarestorage.com
R2_ENDPOINT=https://[CLOUDFLARE-ACCOUNT-ID].r2.cloudflarestorage.com
R2_PUBLIC_URL=https://[R2-PUBLIC-DOMAIN].r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Optional scaffold services ---
YOORA_PROMPT_VERSION=v1
YOORA_QUEUE_NAME=default
