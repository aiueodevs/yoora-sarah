{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@yoora/database": [
        "../packages/database/src/index.ts"
      ],
      "@yoora/database/*": [
        "../packages/database/src/*"
      ],
      "@yoora/ui": [
        "../packages/ui/src/index.ts"
      ],
      "@yoora/ui/*": [
        "../packages/ui/src/*"
      ],
      "@yoora/ui/button": [
        "../packages/ui/src/components/ui/button.tsx"
      ],
      "@yoora/ui/input": [
        "../packages/ui/src/components/ui/input.tsx"
      ],
      "@yoora/ui/lib/utils": [
        "../packages/ui/src/lib/utils.ts"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next-build/types/**/*.ts",
    ".next-build/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
