# Portal local environment
# Copy to: portal/.env.local
# Restart Next.js after editing.

# Required for internal API access.
YOORA_INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
YOORA_INTERNAL_API_SHARED_SECRET=replace-with-the-same-secret-as-root-env

# Required for local portal auth.
YOORA_PORTAL_AUTH_SECRET=replace-with-32-plus-char-secret
YOORA_PORTAL_BOOTSTRAP_PASSWORD=replace-with-temporary-internal-password

# Required if portal needs live Supabase-backed internal data.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SECRET_KEY=sb_secret_[PROJECT-SECRET-KEY]

# Optional if shared browser/server Supabase helpers are used.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_[PROJECT-PUBLISHABLE-KEY]
