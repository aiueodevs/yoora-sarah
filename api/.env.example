# API local environment
# Copy the root .env.example to .env at the repository root for actual local runs.
# This file exists as a quick reference for api-specific values.

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
YOORA_INTERNAL_API_SHARED_SECRET=replace-with-internal-api-shared-secret

# Dev-only fallback auth. Keep false unless you explicitly need insecure local auth.
ALLOW_INSECURE_AUTH=false

# Optional integrations
REDIS_URL=
GROQ_API_KEY=
GEMINI_API_KEY=
