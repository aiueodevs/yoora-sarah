# Web storefront local environment
# Copy to: web/.env.local
# Restart Next.js after editing.

# Required to enable API-backed buyer AI and storefront server routes locally.
YOORA_INTERNAL_API_BASE_URL=http://127.0.0.1:8000/api/v1
YOORA_STOREFRONT_API_BASE_URL=http://127.0.0.1:8000/api/v1
YOORA_INTERNAL_API_SHARED_SECRET=replace-with-the-same-secret-as-root-env

# Optional browser-side storefront API override.
# Leave empty to use the local Next.js proxy at /api/buyer-ai.
NEXT_PUBLIC_YOORA_STOREFRONT_API_URL=

# Optional AI keys for stylist / concierge features.
GROQ_API_KEY=
GEMINI_API_KEY=
