{
  "name": "yoora-sarah-platform",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "portal:install": "npm --prefix apps/portal install --no-package-lock",
    "portal:dev": "npm --prefix apps/portal run dev",
    "portal:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/portal-reset.ps1",
    "portal:build": "npm --prefix apps/portal run build",
    "portal:lint": "npm --prefix apps/portal run lint",
    "portal:typecheck": "npm --prefix apps/portal run typecheck",
    "api:dev": "uv run --directory services/api uvicorn app.main:app --reload --port 8000",
    "workers:run": "uv run --directory services/workers python app/main.py",
    "ai:run": "uv run --directory services/ai python app/main.py",
    "db:status": "uv run --directory tools/db python run_migrations.py status",
    "db:migrate": "uv run --directory tools/db python run_migrations.py migrate",
    "db:seed": "uv run --directory tools/db python run_migrations.py seed"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "puppeteer": "^24.42.0"
  }
}
