{
  "name": "yoora-sarah-platform",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:portal": "npm --prefix portal run dev",
    "api:dev": "uv run --directory api uvicorn app.main:app --reload --port 8000",
    "workers:run": "uv run --directory workers python app/main.py",
    "ai:run": "uv run --directory ai python app/main.py",
    "build:web": "npm --prefix web run build",
    "build:portal": "npm --prefix portal run build",
    "lint:web": "npm --prefix web run lint",
    "lint:portal": "npm --prefix portal run lint",
    "typecheck:web": "npm --prefix web run typecheck",
    "typecheck:portal": "npm --prefix portal run typecheck",
    "test:web": "npm --prefix web run test",
    "test:e2e": "playwright test",
    "db:status": "uv run --directory tools/db python run_migrations.py status",
    "db:migrate": "uv run --directory tools/db python run_migrations.py migrate",
    "db:seed": "uv run --directory tools/db python run_migrations.py seed",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "puppeteer": "^24.42.0"
  }
}
